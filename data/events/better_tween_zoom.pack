better_tween_zoom.hx________PACKSEP________function onEvent(_) {
    if (_.event.name == 'better_tween_zoom') {
        if(_.event.params[4]) defaultCamZoom = Std.parseFloat(_.event.params[0]);
        FlxTween.tween(_.event.params[3] ? camHUD : FlxG.camera, {zoom: _.event.params[0]}, _.event.params[1], {ease: CoolUtil.flxeaseFromString(_.event.params[2])});}
}________PACKSEP________{
	"params": [
		{
			"name": "Zoom",
			"type": "String",
			"defaultValue": "0"
		}, {
			"name": "Time",
			"type": "String",
			"defaultValue": "0"
		}, {
			"name": "Tween",
			"type": "String",
			"defValue": "null"
		}, {
			"name": "CamHUD?",
			"type": "Bool",
			"defaultValue": false
		}, {
			"name": "Set default zoom",
			"type": "Bool",
			"defaultValue": true
		}
	]
}